{
  "name": "convertiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "setup": "bun run scripts/setup-convertiq.ts",
    "setup:dev": "bun run scripts/setup-convertiq.ts --dev",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:isolation": "vitest run --config vitest.isolation.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate:dev": "bun run src/db/migrations/typescript/run-dev-migrations.ts",
    "db:migrate:dev:up": "bun run src/db/migrations/typescript/run-dev-migrations.ts up",
    "db:migrate:dev:down": "bun run src/db/migrations/typescript/run-dev-migrations.ts down",
    "db:migrate:dev:status": "bun run src/db/migrations/typescript/run-dev-migrations.ts status",
    "db:migrate:dev:validate": "bun run src/db/migrations/typescript/run-dev-migrations.ts validate",
    "db:migrate:dev:data": "bun run src/db/migrations/typescript/run-dev-migrations.ts single data up",
    "db:migrate:dev:data-simple": "bun run src/db/migrations/typescript/run-dev-migrations.ts single simple up",
    "db:migrate:dev:data-production": "bun run src/db/migrations/typescript/run-dev-migrations.ts single production up",
    "neon:cleanup": "bun run scripts/neon-branch-cleanup.ts",
    "security:audit": "bun run scripts/security-audit.ts",
    "security:fix-permissions": "chmod 600 .env* 2>/dev/null || true"
  },
